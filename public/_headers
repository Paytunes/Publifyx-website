# Cache rules for Netlify / Cloudflare Pages / Vercel (via _headers convention)
# Hashed assets (JS/CSS built by Vite) — immutable = safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static uploads — images rarely change; 1-year cache
/lovable-uploads/*
  Cache-Control: public, max-age=31536000, immutable

# Public root — no-cache so the browser always revalidates index.html
/
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Favicon / manifest / robots — short cache
/favicon.ico
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=86400
